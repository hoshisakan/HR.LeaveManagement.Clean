{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "ConnectionStrings": {
        // "HrDatabaseConnectionString": "Server=localhost,1441;Database=db_hr_leavemanagement;User Id=sa;Password=HrLeaveManagement@2026!;TrustServerCertificate=True"
        "HrDatabaseConnectionString": "Server=mssql,1433;Database=db_hr_leavemanagement;User Id=sa;Password=HrLeaveManagement@2026!;TrustServerCertificate=True"
    },
    "EmailSettings": {
        "ApiKey": "SendGrid API Key",
        "FromAddress": "no-reply@hrsystems.com",
        "FromName": "HR Management System"
    },
    "Serilog": {
        "Using": ["Serilog", "Serilog.Sinks.Console", "Serilog.Sinks.File"],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.Hosting.Lifetime": "Information"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": "Logs/HR.LeaveManagement.Api.log",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": null
                }
            }
        ]
    },
    "JwtSettings": {
        "Issuer": "HRLeaveManagement.Api",
        "Audience": "HRLeaveManagementUser",
        "Key": "HRLeaveManagementSecretKeyForDevelopmentForTesting",
        "DurationInMinutes": 15
    },
    "Cors": {
        "PolicyName": "WebClient",
        "Origins": [ "http://localhost:5173", "https://localhost" ]
    },
    "AllowedHosts": "*"
}